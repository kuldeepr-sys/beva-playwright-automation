{
  "name": "beva-e2e",
  "version": "1.0.0",
  "description": "Beva E2E Automation Framework",
  "scripts": {
    "test":             "playwright test",
    "test:headed":      "playwright test --headed",
    "test:debug":       "playwright test --debug",
    "test:smoke":       "playwright test --grep @smoke",
    "test:regression":  "playwright test --grep @regression",
    "test:home":        "playwright test tests/Homepage.spec.js",
    "test:login":       "playwright test tests/Player_Log_In.spec.js",
    "test:signup":      "playwright test tests/Player_Sign_Up.spec.js",
    "test:forgot":      "playwright test tests/Player_Forgot_password.spec.js",
    "test:nav":         "playwright test tests/Menu_Navigation.spec.js",
    "test:dashboard":   "playwright test tests/Player_Dashboard.spec.js",
    "test:discover":    "playwright test tests/Player_Discover.spec.js",
    "test:venues":      "playwright test tests/Player_Venues.spec.js",
    "test:profile":     "playwright test tests/Player_profile.spec.js",
    "report":           "playwright show-report"
  },
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5"
  }
}
